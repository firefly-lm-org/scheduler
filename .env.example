# ── 环境 ────────────────────────────────
ENV=development

# ── 数据库 ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://firefly:firefly123@localhost:5432/firefly

# ── Redis ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO ────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=firefly
MINIO_SECRET_KEY=firefly123456
MINIO_BUCKET=firefly-tasks
MINIO_SECURE=false

# ── JWT ──────────────────────────────────
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_ACCESS_EXPIRE=86400
JWT_REFRESH_EXPIRE=604800

# ── 任务配置 ────────────────────────────
TASK_CLAIM_INTERVAL=10
TASK_HEARTBEAT_TIMEOUT=90
TASK_PROGRESS_INTERVAL=60
TASK_MAX_RETRIES=3
